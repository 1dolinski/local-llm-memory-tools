{
  "name": "local-llm-memory-tools",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "start:verbose": "tsx src/index.ts --verbose",
    "benchmark": "tsx scripts/benchmark.ts",
    "benchmark:gemma4": "OLLAMA_MODEL=gemma4 tsx scripts/benchmark.ts",
    "benchmark:9b": "OLLAMA_MODEL=qwen3.5:9b tsx scripts/benchmark.ts",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "ollama": "^0.5.0",
    "apinow-sdk": "^0.14.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0"
  }
}
